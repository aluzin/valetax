{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/valetax-.log",
          "rollingInterval": "Day",
          "shared": true,
          "retainedFileCountLimit": 14
        }
      }
    ]
  },
  "OpenTelemetry": {
    "ServiceName": "Valetax.Api",
    "OtlpEndpoint": ""
  },
  "Authentication": {
    "RememberMeCode": "",
    "Jwt": {
      "Issuer": "Valetax",
      "Audience": "Valetax",
      "SigningKey": ""
    }
  },
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=valetax;Username=valetax;Password=valetax",
    "MigrateOnStartup": true
  },
  "AllowedHosts": "*"
}
